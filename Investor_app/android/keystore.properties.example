# Copy this file to android/keystore.properties and fill with your Play upload key values.
# Do not commit android/keystore.properties.

INVESTFLOW_UPLOAD_STORE_FILE=../keystore/INVESTFLOW-upload-key.jks
INVESTFLOW_UPLOAD_STORE_PASSWORD=change-me
INVESTFLOW_UPLOAD_KEY_ALIAS=INVESTFLOW-upload
INVESTFLOW_UPLOAD_KEY_PASSWORD=change-me

# Optional local override for testing release tasks without production keys.
# Never use this for Play Store artifacts.
# INVESTFLOW_ALLOW_DEBUG_RELEASE_SIGNING=true
